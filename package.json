{
  "name": "storj-uplink-mcp",
  "version": "0.1.0-beta.6",
  "description": "MCP server for Storj decentralized storage — use Storj with Claude, Cursor, Windsurf and any MCP client",
  "type": "module",
  "bin": {
    "storj-uplink-mcp": "./dist/index.js",
    "storj-uplink-mcp-setup": "./dist/setup.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "scripts",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js dist/setup.js",
    "dev": "tsc --watch",
    "postinstall": "node scripts/postinstall.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.15.0",
    "storj-uplink-nodejs": "^0.1.0-beta.23",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5"
  },
  "keywords": [
    "storj",
    "mcp",
    "model-context-protocol",
    "storage",
    "decentralized",
    "claude",
    "cursor",
    "windsurf"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
